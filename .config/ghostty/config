theme = One Double Dark

font-family = "Berkeley Mono"
font-size = 14
font-thicken = true
font-thicken-strength = 250

font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = salt

cursor-style = underline
shell-integration = fish
window-save-state = always
window-height = 45
window-width = 135

term = xterm-256color
keybind = shift+enter=text:\n
